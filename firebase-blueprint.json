{
  "entities": {
    "User": {
      "title": "User",
      "description": "App users representing field sales executives",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the executive"
        },
        "mobile": {
          "type": "string",
          "description": "Mobile contact number used for authentication group"
        },
        "zone": {
          "type": "string",
          "description": "Territory region or sales division zone assigned to the user"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The exact date-time profile registration completed"
        }
      },
      "required": ["name", "mobile", "zone"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Client profile records derived or standalone",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
